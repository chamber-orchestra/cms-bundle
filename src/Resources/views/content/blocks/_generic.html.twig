{#
  Generic content entry renderer. Bootstrap 5 components.

  Usage:
    {{ content_render_entry(entry) }}
  or directly:
    {% include '@ChamberOrchestraCms/content/blocks/_generic.html.twig' with {entry: entry} %}

  Override per ContentType by creating:
    content/blocks/{contentType.name}.html.twig
  in your application templates directory.
#}
{%- import '@ChamberOrchestraImage/macro/image.html.twig' as image -%}
{%- for field in entry.contentType.schema -%}
    {%- set name = field.name -%}
    {%- set type = field.type|default('text') -%}
    {%- set val  = entry.data[name] is defined ? entry.data[name] : null -%}

    {%- if val is not null and val is not same as('') and val is not same as(false) -%}

        {%- if type == 'collection' -%}
            {%- set subSchema = field.schema|default([]) -%}
            {%- set hasImg    = subSchema|filter(f => f.type is defined and f.type == 'image')|length > 0 -%}
            {%- set nonImgFields = subSchema|filter(f => f.type is not defined or f.type != 'image') -%}
            {%- set titleField   = nonImgFields|first -%}

            {%- if hasImg -%}
                {# Card grid for image-based collections (gallery, team, etc.) #}
                {%- set cols = min(val|length, 4) -%}
                <div class="my-3" style="display:grid;grid-template-columns:repeat({{ cols }},1fr);gap:1rem">
                    {%- for item in val|sort((a, b) => (a.sortOrder ?? 0) <=> (b.sortOrder ?? 0)) -%}
                        <div class="card h-100 border-0 shadow-sm">
                                {%- for sf in subSchema -%}
                                    {%- if sf.type == 'image' -%}
                                        {%- set sv = item[sf.name] is defined ? item[sf.name] : null -%}
                                        {%- if sv is not null and sv is not same as('') -%}
                                            {{- image.fill(sv, 600, 400, {class: 'card-img-top', alt: sf.name, style: 'object-fit:cover; height:220px'}) -}}
                                        {%- endif -%}
                                    {%- endif -%}
                                {%- endfor -%}
                                <div class="card-body">
                                    {%- for sf in subSchema -%}
                                        {%- if sf.type is not defined or sf.type != 'image' -%}
                                            {%- set sv = item[sf.name] is defined ? item[sf.name] : null -%}
                                            {%- if sv is not null and sv is not same as('') -%}
                                                {%- if sf.type == 'wysiwyg' -%}
                                                    <div class="card-text">{{- sv|raw -}}</div>
                                                {%- elseif sf.type == 'file' -%}
                                                    <a href="{{ sv }}" class="btn btn-outline-secondary btn-sm mt-2">{{ sv|split('/')|last }}</a>
                                                {%- elseif titleField is not null and sf.name == titleField.name -%}
                                                    <p class="card-title fw-semibold mb-1">{{- sv -}}</p>
                                                {%- else -%}
                                                    <p class="card-text text-muted small">{{- sv -}}</p>
                                                {%- endif -%}
                                            {%- endif -%}
                                        {%- endif -%}
                                    {%- endfor -%}
                                </div>
                        </div>
                    {%- endfor -%}
                </div>

            {%- else -%}
                {# Accordion for text-only collections (FAQ, etc.) #}
                {%- set accordionId = 'acc-' ~ entry.id ~ '-' ~ loop.index -%}
                <div class="accordion my-3" id="{{ accordionId }}">
                    {%- for item in val|sort((a, b) => (a.sortOrder ?? 0) <=> (b.sortOrder ?? 0)) -%}
                        {%- set itemId = accordionId ~ '-' ~ loop.index -%}
                        <div class="accordion-item border-0 border-bottom">
                            <h3 class="accordion-header">
                                <button class="accordion-button {% if not loop.first %}collapsed{% endif %} px-0 fw-semibold"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#{{ itemId }}"
                                        aria-expanded="{{ loop.first ? 'true' : 'false' }}"
                                        aria-controls="{{ itemId }}">
                                    {{- titleField is not null and item[titleField.name] is defined ? item[titleField.name] : '' -}}
                                </button>
                            </h3>
                            <div id="{{ itemId }}"
                                 class="accordion-collapse collapse {% if loop.first %}show{% endif %}"
                                 data-bs-parent="#{{ accordionId }}">
                                <div class="accordion-body px-0">
                                    {%- for sf in subSchema -%}
                                        {%- if titleField is null or sf.name != titleField.name -%}
                                            {%- set sv = item[sf.name] is defined ? item[sf.name] : null -%}
                                            {%- if sv is not null and sv is not same as('') -%}
                                                {%- if sf.type == 'wysiwyg' -%}
                                                    {{- sv|raw -}}
                                                {%- elseif sf.type == 'file' -%}
                                                    <a href="{{ sv }}" class="btn btn-outline-secondary btn-sm">{{ sv|split('/')|last }}</a>
                                                {%- else -%}
                                                    <p class="text-muted mb-0">{{- sv -}}</p>
                                                {%- endif -%}
                                            {%- endif -%}
                                        {%- endif -%}
                                    {%- endfor -%}
                                </div>
                            </div>
                        </div>
                    {%- endfor -%}
                </div>

            {%- endif -%}

        {%- elseif type == 'image' -%}
            {%- set uri = val is instanceof('string') ? val : (val.uri is defined ? val.uri : null) -%}
            {%- if uri -%}
                <div class="my-3">{{- image.fit(uri, 900, 0, {class: 'img-fluid rounded', alt: name}) -}}</div>
            {%- endif -%}

        {%- elseif type == 'file' -%}
            {%- set uri = val is instanceof('string') ? val : (val.uri is defined ? val.uri : null) -%}
            {%- if uri -%}
                <div class="my-2">
                    <a href="{{ uri }}" class="btn btn-outline-secondary btn-sm">
                        <i class="far fa-file me-1"></i>{{ uri|split('/')|last }}
                    </a>
                </div>
            {%- endif -%}

        {%- elseif type == 'wysiwyg' -%}
            {%- if val is instanceof('string') -%}{{- val|raw -}}{%- endif -%}

        {%- else -%}
            {%- if val is instanceof('string') -%}<p class="medium-text">{{- val -}}</p>{%- endif -%}

        {%- endif -%}

    {%- endif -%}
{%- endfor -%}
