{%- use "bootstrap_5_layout.html.twig" -%}

{%- block form_widget_compound -%}
    {# compound widget can have errors #}
    <fieldset {{ block('widget_container_attributes') }}>
        {%- if form is rootform -%}
            {{ form_errors(form) }}
        {%- endif -%}
        {{- block('form_rows') -}}
        {{- form_rest(form) -}}
    </fieldset>
{%- endblock form_widget_compound -%}

{%- block form_widget_simple -%}
    {%- if group_attr is defined -%}
        {%- set group_attr = group_attr|default({})|merge({class: (group_attr.class|default('') ~ ' input-group')|trim}) -%}
        <div {% with { attr: group_attr } %}{{ block('attributes') }}{% endwith %} >
            {%- if prepend is defined -%}
                {{- prepend|raw -}}
            {%- endif -%}
            {{- parent() -}}
            {%- if append is defined -%}
                {{- append|raw -}}
            {%- endif -%}
        </div>
    {%- else -%}
        {{- parent() -}}
    {%- endif -%}
{%- endblock form_widget_simple -%}

{% block form_label -%}
    {% if label is not same as(false) -%}
        {%- if compound is defined and compound -%}
            {%- set element = 'legend' -%}
            {%- if 'col-form-label' not in  label_attr.class|default('') -%}
                {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' col-form-label')|trim}) -%}
            {%- endif -%}
        {%- else -%}
            {%- set label_attr = label_attr|merge({for: id}) -%}
        {%- endif -%}
        {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' form-label')|trim}) -%}
        {% if required -%}
            {% set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' required')|trim}) %}
        {%- endif -%}
        {% if label is empty -%}
            {%- if label_format is not empty -%}
                {% set label = label_format|replace({
                    '%name%': name,
                    '%id%': id,
                }) %}
            {%- else -%}
                {% set label = name|humanize %}
            {%- endif -%}
        {%- endif -%}
        <{{ element|default('label') }}{% if label_attr %}{% with { attr: label_attr } %}{{ block('attributes') }}{% endwith %}{% endif %}>
        {{- translation_domain is same as(false) ? label : label|trans(label_translation_parameters, translation_domain) -}}
        {%- if required -%}
            <span class="visually-hidden">{{- 'common.required'|trans({}, 'cms') -}}</span>
        {%- endif -%}
        </{{ element|default('label') }}>
    {%- else -%}
        {%- if errors|length > 0 -%}
            <div id="{{ id }}_errors" class="mb-2">
                {{- form_errors(form) -}}
            </div>
        {%- endif -%}
    {%- endif -%}
{%- endblock form_label %}


{%- block form_start -%}
    {%- set attr = attr|merge({novalidate: "novalidate"}) -%}
    {%- set attr = attr|merge({"data-form": form.vars.name}) -%}
    {%- if attr.id is not defined -%}
        {%- set attr = attr|merge({"id": form.vars.id}) -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock form_start -%}


{% block form_row -%}

    {%- if compound is defined and compound -%}
        {%- set element = 'fieldset' -%}
    {%- endif -%}
    {%- set widget_attr = {} -%}
    {%- if help is not empty -%}
        {%- set widget_attr = {attr: {'aria-describedby': id ~"_help"}} -%}
    {%- endif -%}
    {%- set row_attr = row_attr|default({})|merge({class: (row_attr.class|default('') ~ ' form-group')|trim}) -%}

    <{{ element|default('div') }} {% with { attr: row_attr|default({}) } %}{{ block('attributes') }}{% endwith %}>
    {{- form_label(form) -}}
    {{- form_widget(form, widget_attr) -}}
    {{- form_help(form) -}}
    {{- form_errors(form) -}}
    </{{ element|default('div') }}>
{%- endblock form_row %}


{%- block radio_widget -%}
    {%- if 'radio-custom' not in parent_label_class|default('') -%}
        {%- set parent_label_class = (parent_label_class|default('') ~ '  radio-custom')|trim -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock -%}


{%- block checkbox_widget -%}
    {%- if 'checkbox-custom' not in parent_label_class|default('') -%}
        {%- set parent_label_class = (parent_label_class|default('') ~ '  checkbox-custom')|trim -%}
    {%- endif -%}

    {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' checkbox-custom')|trim}) -%}
    {%- if force_inline is defined and force_inline -%}
        {%- set widget -%}
            <input type="checkbox" {{ block('widget_attributes') }}{% if value is defined %} value="{{ value }}"{% endif %}{% if checked %} checked="checked"{% endif %} />
        {%- endset -%}
        {{- form_label(form, null, { widget: widget }) -}}
    {%- else -%}
        {{- parent() -}}
    {%- endif -%}
{%- endblock -%}


{% block checkbox_radio_label -%}
    {#- Do not display the label if widget is not defined in order to prevent double label rendering       -#}
    {%- if widget is defined -%}
        {%- set force_inline = force_inline|default(false) -%}
        {%- if not force_inline -%}
            {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' form-check-label')|trim}) -%}
        {%- endif -%}
        {%- if not compound -%}
            {% set label_attr = label_attr|merge({'for': id}) %}
        {%- endif -%}
        {%- if required -%}
            {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' required')|trim}) -%}
        {%- endif -%}
        {%- if parent_label_class is defined -%}
            {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' ' ~ parent_label_class)|replace({'checkbox-inline': '', 'radio-inline': '', 'checkbox-custom': '', 'radio-custom': ''})|trim}) -%}
        {%- endif -%}
        {%- if label is not same as(false) and label is empty -%}
            {%- if label_format is not empty -%}
                {%- set label = label_format|replace({
                    '%name%': name,
                    '%id%': id,
                }) -%}
            {%- else -%}
                {%- set label = name|humanize -%}
            {%- endif -%}
        {%- endif -%}

        {%- if force_inline -%}
            <label{% with { attr: label_attr } %}{{ block('attributes') }}{% endwith %}>
                {{- widget|raw -}}
                {{- label is not same as(false) ? (translation_domain is same as(false) ? label : label|trans({}, translation_domain)|raw) -}}
            </label>
        {%- else -%}
            {{- widget|raw -}}
            <label{% with { attr: label_attr } %}{{ block('attributes') }}{% endwith %}>
                {{- label is not same as(false) ? (translation_domain is same as(false) ? label : label|trans({}, translation_domain)|raw) -}}
            </label>
        {%- endif -%}
    {%- endif -%}
{%- endblock checkbox_radio_label %}



{% block form_errors -%}
    {%- set template -%}
        {%- apply spaceless -%}
            <span class="mb-0 d-block">
                <span class="form-error-message">__error__</span>
            </span>
        {%- endapply -%}
    {%- endset -%}
    {%- if form is not rootform -%}
        <span class="invalid-tooltip" id="{{ form.vars.id }}_error">
            {%- for error in errors -%}
                {{- template|replace({'__error__': error.message})|raw -}}
            {%- endfor -%}
        </span>
    {%- else -%}
        {%- if errors|length > 0 -%}
            <div class="alert alert-danger d-block">
                {%- for error in errors -%}
                    {{- template|replace({'__error__': error.message})|raw -}}
                {%- endfor -%}
            </div>
        {%- endif -%}
    {%- endif -%}
{%- endblock form_errors -%}



{%- block date_widget -%}
    {%- if widget == 'single_text' -%}
        {%- if not required -%}
            {%- set append -%}
                <button type="button" {#
                #}class="btn btn-outline-danger" {#
                        #}data-clear><i class="far fa-times fa-fw"></i></button>
            {%- endset -%}
        {%- endif -%}

        {%- set prepend -%}
            <span class="input-group-text">
                <i class="fad fa-fw fa-calendar"></i>
            </span>
        {%- endset -%}

        {%- set attr = attr|default({})|merge({
            "data-input": true,
            "autocomplete": 'off'
        }) -%}
        {%- set group_attr = {'data-group': 'date'} -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock -%}


{%- block datetime_widget -%}
    {%- if widget == 'single_text' -%}
        {%- if not required -%}
            {%- set append -%}
                <button type="button" {#
                #}class="btn btn-outline-danger" {#
                        #}data-clear><i class="far fa-times fa-fw"></i></button>
            {%- endset -%}
        {%- endif -%}

        {%- set prepend -%}
            <span class="input-group-text">
                <i class="fad fa-fw fa-calendar"></i>
            </span>
            <span class="input-group-text">
                <i class="fad fa-fw fa-clock"></i>
            </span>
        {%- endset -%}


        {%- set attr = attr|default({})|merge({
            "data-input": true,
            "autocomplete": 'off'
        }) -%}
        {%- set group_attr = {'data-group': 'datetime'} -%}
    {%- endif -%}
    {{- parent() -}}
{%- endblock -%}

{%- block collection_widget -%}
    {%- apply spaceless -%}
        {%- set delete_prototype -%}
            {%- if form.vars.allow_delete -%}
                <button type="button" class="btn btn-danger btn-sm" {#
                #} data-toggle="remove" {#
                #} data-target="#{{ form.vars.id }}" {#
                #} aria-label="{{- "collection.field.delete"|trans({}, 'cms') -}}" {#
                #} title="{{- "collection.field.delete"|trans({}, 'cms') -}}">{#
                    #}<i class="far fa-times"></i>{#
                    #}</button>
            {%- endif -%}
            {%- if prototype['sortOrder'] is defined -%}
                <button type="button" {#
                #} aria-label="{{ 'common.move_up'|trans({}, 'cms') }}" {#
                #} title="{{ 'common.move_up'|trans({}, 'cms') }}" {#
                #} class="btn btn-sm btn-warning" {#
                #} data-target="#{{ form.vars.id }}" {#
                #} data-move="up">
                    <i class="far fa-angle-up"></i>
                </button>
                <button type="button" {#
                #} class="btn btn-sm btn-warning" {#
                #} aria-label="{{ 'common.move_down'|trans({}, 'cms') }}" {#
                #} title="{{ 'common.move_down'|trans({}, 'cms') }}" {#
                #} data-target="#{{ form.vars.id }}" {#
                #} data-move="down">
                    <i class="far fa-angle-down"></i>
                </button>
            {%- endif -%}
        {%- endset -%}


        {%- set move_prototype -%}
        {%- endset -%}
        {%- set attr = attr|default({})|merge({
            'data-collection': true,
        }) -%}

        {%- if prototype is defined -%}
            {%- set _prototype = prototype -%}
            {%- set prototype -%}
                {%- form_theme prototype with ['@ChamberOrchestraCms/form/inline.html.twig'] only -%}
                <span class="collection-actions">
                    <span class="btn-group">
                        {{- move_prototype -}}
                        {{- delete_prototype -}}
                    </span>
                </span>
                {{- form_row(_prototype, {label: false }) -}}
            {%- endset -%}

            {%- set attr = attr|merge({
                'data-collection-name': _prototype.vars.full_name, '
                 data-collection-id': _prototype.vars.id,
                'data-counter': form|length,
                'data-prototype': prototype|e('html_attr'),
                'data-widget-tags': '<li data-collection-element></li>'|e('html_attr'),
            }) -%}
        {%- endif -%}

        <ol id="{{ form.vars.id }}" class="list-collection" {#
        #}{% with { attr: attr } %}{{ block('attributes') }}{% endwith %}>
            {%- for entry in form -%}
                <li data-collection-element>
                    {%- form_theme entry with ['@ChamberOrchestraCms/form/inline.html.twig'] only -%}
                    <span class="collection-actions">
                        <span class="btn-group">
                            {{- move_prototype -}}
                            {{- delete_prototype -}}
                        </span>
                    </span>
                    {{- form_row(entry, {label: false}) -}}
                </li>
            {%- endfor -%}
        </ol>
        {%- if form.vars.allow_add -%}
            <div>
                <button type="button" class="btn btn-outline-success" data-toggle="add" {#
                #}data-target="#{{ form.vars.id }}">{#
                    #}<i class="fas fa-fw fa-plus-square"></i>&nbsp;{{- "collection.field.add"|trans({}, 'cms') -}}{#
                    #}</button>
            </div>
        {%- endif -%}
    {%- endapply -%}
{%- endblock collection_widget -%}

{% block choice_label -%}
    {# remove the checkbox-inline and radio-inline class, it's only useful for embed labels #}
    {%- set label_attr = label_attr|merge({class: (label_attr.class|default('') ~ ' ' ~ label_attr.parent_label_class|default(''))|trim}) -%}
    {{- parent() -}}
{% endblock choice_label %}

{% block choice_widget_collapsed -%}
    {%- set attr = attr|merge({class: (attr.class|default('') ~ ' form-select')|trim}) -%}
    {{- parent() -}}
{%- endblock choice_widget_collapsed %}


{%- block dev_recaptcha_widget -%}
    <div class="recaptcha-container form-group">
        {{- form_widget(form) -}}
        {{- form_errors(form) -}}
    </div>
{%- endblock -%}




{% block form_help -%}
    {%- if help is not empty -%}
        {%- set help_attr = help_attr|merge({class: (help_attr.class|default('') ~ ' form-text text-body-secondary')|trim}) -%}
        <small id="{{ id }}_help"{% with { attr: help_attr } %}{{ block('attributes') }}{% endwith %}>
            {%- if translation_domain is same as(false) -%}
                {%- if help_html is same as(false) -%}
                    {{- help|nl2br -}}
                {%- else -%}
                    {{- help|raw|nl2br -}}
                {%- endif -%}
            {%- else -%}
                {%- if help_html is same as(false) -%}
                    {{- help|trans(help_translation_parameters, translation_domain)|nl2br -}}
                {%- else -%}
                    {{- help|trans(help_translation_parameters, translation_domain)|raw|nl2br -}}
                {%- endif -%}
            {%- endif -%}
        </small>
    {%- endif -%}
{%- endblock form_help %}

{% block background_color_row %}
    <div class="form-group row">
        {{ form_label(form.color) }}
        <div class="{{ block('form_group_class') }}">
            {{ form_widget(form.color, { attr: {'class': 'js-color-field'} }) }}
            {{ form_errors(form.color) }}

            <div class="form-check mt-2 ps-0">
                {{ form_widget(form.reset, { attr: {'class': 'js-reset-checkbox'} }) }}
                {{ form_label(form.reset) }}
            </div>
            {{ form_errors(form.reset) }}
        </div>
    </div>
{% endblock %}

{% block form_footer_color_row %}
    <div class="form-group row">
        {{ form_label(form.color) }}
        <div class="{{ block('form_group_class') }}">
            {{ form_widget(form.color, { attr: {'class': 'js-footer-color-field'} }) }}
            {{ form_errors(form.color) }}

            <div class="form-check mt-2 ps-0">
                {{ form_widget(form.use_default, { attr: {'class': 'js-footer-color-checkbox'} }) }}
                {{ form_label(form.use_default) }}
            </div>
            {{ form_errors(form.use_default) }}
        </div>
    </div>
{% endblock %}


